---
export const prerender = false;

import { search } from "emdash";
import Base from "../layouts/Base.astro";
import SearchForm from "../components/SearchForm.astro";
import SearchResults from "../components/SearchResults.astro";

// Limit query length to prevent search DoS / excessive resource usage
const MAX_QUERY_LENGTH = 200;
const rawQuery = Astro.url.searchParams.get("q")?.trim() || "";
const query = rawQuery.length > MAX_QUERY_LENGTH ? rawQuery.slice(0, MAX_QUERY_LENGTH) : rawQuery;

// Use the FTS-backed search() API instead of loading every post and
// filtering in JS. FTS scales as the post count grows, returns ranked
// results, and handles tokenization/stemming. Templates that grep all
// post bodies in JS quickly become unusable past a few hundred posts.
const { items: results } = query
	? await search(query, { collections: ["posts"], limit: 30 })
	: { items: [] };
---

<Base
	title={query ? `搜索：${query}` : "搜索"}
	description="搜索博客文章"
>
	<section class="search-page">
		<h1 class="search-title">搜索</h1>

		<SearchForm query={query} />

		{
			query && (
				<p class="search-summary">
					{results.length === 0
						? `未找到"${query}"的相关结果`
						: `${results.length} 条"${query}"的搜索结果`}
				</p>
			)
		}

		{results.length > 0 && <SearchResults results={results} />}

		{!query && <p class="search-hint">输入关键词搜索文章。</p>}
	</section>
</Base>

<style>
	.search-page {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.search-title {
		font-size: var(--font-size-2xl);
		margin-bottom: var(--spacing-6);
	}

	.search-summary {
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	.search-hint {
		color: var(--color-muted);
	}
</style>
