---
import ImageRenderer from "./ImageRenderer.astro";

interface Props {
	image: any;
	title: string;
	edit?: any;
}

const { image, title, edit } = Astro.props;
---

{
	image && (
		<div class="article-hero reveal" {...edit}>
			<ImageRenderer
				image={image}
				alt={title || ""}
				width={image?.width}
				height={image?.height}
			/>
		</div>
	)
}

<style>
	@keyframes heroFadeIn {
		from {
			opacity: 0;
			transform: translateY(20px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.article-hero {
		margin: var(--spacing-16) var(--spacing-6);
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-surface);
		aspect-ratio: 16 / 9;
		animation: heroFadeIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.article-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (max-width: 900px) {
		.article-hero {
			margin: var(--spacing-4) var(--spacing-4) var(--spacing-8);
			border-radius: var(--radius);
		}
	}
</style>
