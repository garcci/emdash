---
import ImageRenderer from "./ImageRenderer.astro";

interface Props {
	image: any;
	title: string;
	edit?: any;
}

const { image, title, edit } = Astro.props;
---

{
	image && (
		<div class="article-hero" {...edit}>
			<ImageRenderer
				image={image}
				alt={title || ""}
				width={image?.width}
				height={image?.height}
			/>
		</div>
	)
}

<style>
	.article-hero {
		margin: var(--spacing-16) var(--spacing-6);
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-surface);
		aspect-ratio: 16 / 9;
	}

	.article-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (max-width: 900px) {
		.article-hero {
			margin: var(--spacing-4) var(--spacing-4) var(--spacing-8);
			border-radius: var(--radius);
		}
	}
</style>
