---
import PostCard from "./PostCard.astro";
import { getReadingTime } from "../utils/reading-time";
import type { EmDashEntry } from "emdash";

interface TermInfo {
	slug: string;
	label: string;
}

interface Props {
	posts: Array<{
		post: EmDashEntry;
		tags: TermInfo[];
	}>;
}

const { posts } = Astro.props;
---

{
	posts.length === 0 ? (
		<p class="no-posts">暂无文章。</p>
	) : (
		<div class="posts-grid">
			{posts.map(({ post, tags }) => (
				<PostCard
					title={post.data.title}
					excerpt={post.data.excerpt}
					featuredImage={post.data.featured_image}
					href={`/posts/${post.id}`}
					date={post.data.publishedAt ?? undefined}
					readingTime={getReadingTime(post.data.content)}
					tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
				/>
			))}
		</div>
	)
}

<style>
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	.no-posts {
		color: var(--color-muted);
	}

	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
