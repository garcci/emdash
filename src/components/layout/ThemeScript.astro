---
// Inline theme script: must run before paint to avoid flash
---

<meta name="color-scheme" content="light dark" />

<script is:inline>
	// Apply system preference only if no explicit theme class is already set (SSR)
	(function () {
		var root = document.documentElement;
		// If server already applied a theme class, do nothing
		if (root.classList.contains("dark") || root.classList.contains("light")) {
			return;
		}
		// Otherwise, fall back to system preference
		if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
			root.classList.add("dark");
		}
	})();
</script>

<script is:inline>
	// Theme switcher controls
	const THEME_REGEX = /theme=([^;]+)/;
	var themeBtns =
		document.querySelectorAll(".theme-btn");
	var root = document.documentElement;

	function setCookie(
		name,
		value,
		maxAge
	) {
		maxAge = maxAge || 31536000;
		var secure = location.protocol === "https:" ? "; Secure" : "";
		if (value === "") {
			document.cookie = name + "=; path=/; max-age=0; SameSite=Lax" + secure;
		} else {
			document.cookie = name + "=" + value + "; path=/; max-age=" + maxAge + "; SameSite=Lax" + secure;
		}
	}

	function setTheme(theme) {
		if (theme === "system") {
			setCookie("theme", "");
			root.classList.remove("light", "dark");
			if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
				root.classList.add("dark");
			}
		} else {
			setCookie("theme", theme);
			root.classList.remove("light", "dark");
			root.classList.add(theme);
		}
		updateActiveBtn(theme);
	}

	function updateActiveBtn(theme) {
		themeBtns.forEach(function(btn) {
			btn.classList.toggle("active", btn.dataset.theme === theme);
		});
	}

	function getStoredTheme() {
		var match = document.cookie.match(THEME_REGEX);
		return match ? match[1] : "system";
	}

	// Initialize active button state only (theme already applied by inline script above)
	var storedTheme = getStoredTheme();
	updateActiveBtn(storedTheme);

	themeBtns.forEach(function(btn) {
		btn.addEventListener("click", function() {
			setTheme(btn.dataset.theme || "system");
		});
	});

	// Listen for system preference changes
	window
		.matchMedia("(prefers-color-scheme: dark)")
		.addEventListener("change", function(e) {
			if (getStoredTheme() === "system") {
				root.classList.toggle("dark", e.matches);
			}
		});
</script>
