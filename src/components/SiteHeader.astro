---
import LiveSearch from "emdash/ui/search";
import { safeUrl } from "../utils/url-security";

interface MenuItem {
	url: string;
	target?: string;
	label: string;
}

interface Props {
	siteTitle: string;
	siteLogo?: { url: string; alt?: string } | null;
	menuItems?: MenuItem[];
	isLoggedIn: boolean;
}

const { siteTitle, siteLogo, menuItems = [], isLoggedIn } = Astro.props;

// Sanitize logo URL before rendering in img src
const sanitizedLogoUrl = siteLogo?.url ? safeUrl(siteLogo.url, "") : "";
// Get current path for aria-current
const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<nav class="nav" aria-label="主导航">
		<a href="/" class="site-title">
			{
				siteLogo
					? <img src={sanitizedLogoUrl} alt={siteLogo.alt || siteTitle} class="site-logo-img" />
					: siteTitle
			}
		</a>
		<div class="nav-right">
			<LiveSearch
				placeholder="搜索文章..."
				class="site-search"
				inputClass="site-search-input"
				resultsClass="site-search-results"
				resultClass="site-search-result"
				collections={["posts", "pages"]}
			/>
			<div class="nav-links">
				{
					menuItems.map((item) => (
						<a 
							href={item.url} 
							target={item.target}
							aria-current={currentPath === item.url || (item.url !== '/' && currentPath.startsWith(item.url)) ? 'page' : undefined}
							aria-label={item.label}
						>
							{item.label}
						</a>
					))
				}
			</div>
		</div>
		{
			isLoggedIn && (
				<a href="/_emdash/admin" class="nav-admin">
					管理
				</a>
			)
		}
	</nav>
</header>

<style is:global>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		/* Glassmorphism: reduced blur/saturate for lower GPU cost per frame.
		 * Old values (blur(24px) saturate(1.6)) caused noticeable compositor
		 * overhead during scroll on mid-range devices.
		 */
		background: color-mix(in srgb, var(--color-bg) 65%, transparent);
		backdrop-filter: blur(12px) saturate(1.2);
		-webkit-backdrop-filter: blur(12px) saturate(1.2);
		/* Subtle bottom border with glass feel */
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 30%, transparent);
		/* Top edge highlight — simulates glass refraction */
		box-shadow: inset 0 1px 0 0 color-mix(in srgb, var(--color-text) 4%, transparent);
	}

	/* Fallback for browsers without backdrop-filter support */
	@supports not (backdrop-filter: blur(12px)) {
		.site-header {
			background: var(--color-bg);
		}
	}

	.nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4) var(--spacing-6);
		height: var(--nav-height);
	}

	.site-title {
		font-size: var(--font-size-lg);
		font-weight: 600;
		color: var(--color-text);
		text-decoration: none;
		letter-spacing: var(--tracking-snug);
		transition: color var(--transition-fast);
	}

	.site-title:hover {
		color: var(--color-accent);
	}

	.site-logo-img {
		height: 48px;
		width: auto;
		display: block;
		margin: -8px 0;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: var(--spacing-6);
		margin-inline-start: auto;
	}

	.nav-links {
		display: flex;
		gap: var(--spacing-5);
		font-size: var(--font-size-sm);
	}

	.nav-links a {
		text-decoration: none;
		color: var(--color-text);
		transition: color var(--transition-fast);
		position: relative;
	}

	.nav-links a::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 50%;
		width: 0;
		height: 1.5px;
		background: var(--color-accent);
		transition:
			width 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			left 0.3s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.nav-links a:hover {
		color: var(--color-accent);
	}

	.nav-links a:hover::after {
		width: 100%;
		left: 0;
	}

	.nav-links a:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
		border-radius: var(--radius);
	}

	.nav-admin {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.nav-admin:hover {
		color: var(--color-text);
	}

	/* Search styling */
	.site-search {
		position: relative;
		width: var(--search-input-width);
		--emdash-search-border-focus: var(--color-accent);
	}

	.site-search-input {
		width: var(--search-input-width);
		padding: var(--spacing-2) var(--spacing-3);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-bg);
		color: var(--color-text);
		transition:
			border-color var(--transition-fast),
			box-shadow var(--transition-fast),
			background var(--transition-fast);
	}

	.site-search-input:hover {
		background: var(--color-bg-subtle);
	}

	.site-search-input:focus,
	.site-search-input:focus-visible {
		outline: none;
		border-color: var(--color-accent) !important;
		box-shadow: 0 0 0 3px var(--color-accent-ring);
		background: var(--color-bg);
	}

	.site-search-results {
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		margin-top: var(--spacing-2);
		/* Glassmorphism search panel */
		background: color-mix(in srgb, var(--color-bg) 80%, transparent);
		backdrop-filter: blur(20px) saturate(1.4);
		-webkit-backdrop-filter: blur(20px) saturate(1.4);
		border: 1px solid color-mix(in srgb, var(--color-border) 35%, transparent);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-glass);
		max-height: 400px;
		overflow-y: auto;
		z-index: 1000;
	}

	.site-search-results .emdash-live-search-loading,
	.site-search-results .emdash-live-search-no-results {
		padding: var(--spacing-4);
		text-align: center;
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.site-search-result {
		display: block;
		padding: var(--spacing-3) var(--spacing-4);
		text-decoration: none;
		color: var(--color-text);
		border-bottom: 1px solid var(--color-border-subtle);
		transition: background var(--transition-fast);
	}

	.site-search-result:last-child {
		border-bottom: none;
	}

	.site-search-result:hover,
	.site-search-result:focus,
	.site-search-result.focused {
		background: var(--color-surface);
		outline: none;
	}

	.site-search-result .emdash-live-search-result-title {
		display: block;
		font-weight: 500;
		font-size: var(--font-size-sm);
	}

	.site-search-result .emdash-live-search-result-collection {
		display: block;
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		margin-top: 2px;
	}

	.site-search-result .emdash-live-search-result-snippet {
		display: block;
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-top: var(--spacing-1);
		line-height: var(--leading-snug);
	}

	.site-search-result .emdash-live-search-result-snippet mark {
		font-weight: 600;
		color: var(--color-text);
	}

	@media (max-width: 640px) {
		.site-header {
			position: relative;
			border-bottom: none;
		}

		.nav {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: center;
			height: auto;
			column-gap: var(--spacing-3);
			row-gap: var(--spacing-2);
			padding: var(--spacing-3) var(--spacing-4);
		}

		.site-title {
			grid-column: 1;
			grid-row: 1;
			font-size: var(--font-size-base);
			min-width: 0;
		}

		.nav-right {
			grid-column: 1 / -1;
			grid-row: 2;
			display: grid;
			row-gap: var(--spacing-2);
		}

		.site-search {
			grid-column: 1;
			width: 100%;
			max-width: none;
		}

		.site-search-input {
			width: 100% !important;
			padding: var(--spacing-1) var(--spacing-2) !important;
			font-size: var(--font-size-sm) !important;
		}

		.nav-links {
			grid-column: 1;
			display: flex;
			column-gap: var(--spacing-3);
			row-gap: var(--spacing-1);
			flex-wrap: wrap;
			justify-content: flex-start;
		}

		.nav-admin {
			grid-column: 2;
			grid-row: 1;
			justify-self: end;
			font-size: var(--font-size-xs);
			margin-inline-start: 0;
			white-space: nowrap;
		}
	}
</style>
