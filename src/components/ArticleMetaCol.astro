---
import BylineCard from "./BylineCard.astro";

interface Props {
	bylines: Array<{
		byline: { avatarMediaId?: string | null; displayName: string };
	}>;
	publishDate?: string | null;
	readingTime: string;
	tags: Array<{ slug: string; label: string }>;
}

const { bylines, publishDate, readingTime, tags } = Astro.props;
---

<aside class="article-meta-col reveal">
	<div class="meta-sticky">
		{
			bylines.length > 0 && (
				<div class="meta-block byline-block">
					<span class="meta-label">作者</span>
					<div class="bylines">
						<BylineCard credits={bylines} />
					</div>
				</div>
			)
		}
		{
			publishDate && (
				<div class="meta-block">
					<span class="meta-label">发布于</span>
					<time class="meta-value">{publishDate}</time>
				</div>
			)
		}
		<div class="meta-block">
			<span class="meta-label">阅读时间</span>
			<span class="meta-value">{readingTime} 分钟</span>
		</div>
		{
			tags.length > 0 && (
				<div class="meta-block">
					<span class="meta-label">标签</span>
					<div class="meta-tags">
						{tags.map((t) => (
							<a href={`/tag/${t.slug}`} class="meta-tag">
								{t.label}
							</a>
						))}
					</div>
				</div>
			)
		}
	</div>
</aside>

<style>
	.article-meta-col {
		display: block;
	}

	.meta-sticky {
		position: sticky;
		top: calc(var(--nav-height) + var(--spacing-8));
	}

	.meta-block {
		margin-bottom: var(--spacing-6);
	}

	.meta-label {
		display: block;
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-muted);
		margin-bottom: var(--spacing-1);
	}

	.meta-value {
		display: block;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.meta-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-1);
	}

	.meta-tag {
		display: inline-block;
		padding: var(--tag-padding-y) var(--spacing-2);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		background: var(--color-surface);
		border-radius: var(--radius);
		text-decoration: none;
		transition:
			color var(--transition-fast),
			background var(--transition-fast),
			transform var(--transition-fast);
	}

	.meta-tag:hover {
		color: var(--color-text);
		background: var(--color-border);
		transform: translateX(1px);
	}

	.meta-tag:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.bylines {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}
</style>
