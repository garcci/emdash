# Cloudflare Pages custom headers
# https://developers.cloudflare.com/pages/platform/headers/

# HTML pages — always revalidate (content may change)
/*
  Cache-Control: public, max-age=0, must-revalidate
  # Prevent clickjacking
  X-Frame-Options: DENY
  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff
  # Control referrer information
  Referrer-Policy: strict-origin-when-cross-origin
  # Restrict browser features
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  # Content Security Policy — strict policy for Astro + EmDash
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; media-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self';

# Astro hashed assets (CSS, JS, fonts) — immutable, cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
